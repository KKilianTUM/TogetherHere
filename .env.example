# TogetherHere environment template
# Copy to .env for local development only.
# Do NOT commit real values.

# App
NODE_ENV=development
PORT=3000

# Database (non-sensitive placeholder)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?sslmode=require

# Auth / tokens (non-sensitive placeholders)
ACCESS_TOKEN_PRIVATE_KEY_PEM=<base64_pem_private_key>
ACCESS_TOKEN_PUBLIC_KEY_PEM=<base64_pem_public_key>
REFRESH_TOKEN_PRIVATE_KEY_PEM=<base64_pem_private_key>
REFRESH_TOKEN_PUBLIC_KEY_PEM=<base64_pem_public_key>
TOKEN_ACTIVE_KID=<current_key_id>
TOKEN_ALLOWED_KIDS=<key_id_1,key_id_2>

# Encryption keys (envelope/keyset placeholders)
ENCRYPTION_ACTIVE_KEY_ID=<current_encryption_key_id>
ENCRYPTION_ALLOWED_KEY_IDS=<enc_key_id_1,enc_key_id_2>

# SMTP (non-sensitive placeholders)
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=<smtp_username>
SMTP_PASSWORD=<smtp_password>
SMTP_FROM=noreply@example.com

# Cloud secret manager integration
# Examples: aws-secrets-manager | gcp-secret-manager | azure-key-vault
SECRETS_PROVIDER=aws-secrets-manager
SECRETS_PREFIX=/togetherhere/dev
AWS_REGION=eu-central-1
