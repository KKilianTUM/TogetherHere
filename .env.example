# TogetherHere environment template
# Copy to .env for local development only.
# Do NOT commit real values.

# App
NODE_ENV=development
PORT=3000

# Database reference (store actual credentials in secret manager)
DATABASE_SECRET_ID=/togetherhere/<env>/db

# Token key references (store key material in KMS/HSM or secret manager)
TOKEN_ACTIVE_KID=<current_signing_kid>
TOKEN_ALLOWED_KIDS=<signing_kid_1,signing_kid_2>
TOKEN_KEYS_SECRET_ID=/togetherhere/<env>/tokens
TOKEN_JWKS_PATH=/.well-known/jwks.json

# Encryption key references
ENCRYPTION_ACTIVE_KEY_ID=<current_encryption_key_id>
ENCRYPTION_ALLOWED_KEY_IDS=<enc_key_id_1,enc_key_id_2>
ENCRYPTION_KEYS_SECRET_ID=/togetherhere/<env>/encryption

# SMTP credentials reference
SMTP_SECRET_ID=/togetherhere/<env>/smtp
SMTP_FROM=noreply@example.com

# Cloud secret manager integration
# Examples: aws-secrets-manager | gcp-secret-manager | azure-key-vault
SECRETS_PROVIDER=aws-secrets-manager
SECRETS_PREFIX=/togetherhere/dev
AWS_REGION=eu-central-1
