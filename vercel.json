{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/auth",
      "destination": "https://api.yourdomain.com/auth"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://api.yourdomain.com/auth/:path*"
    },
    {
      "source": "/csrf-token",
      "destination": "https://api.yourdomain.com/csrf-token"
    }
  ]
}
