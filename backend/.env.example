# TogetherHere backend baseline environment template
# Copy to .env and provide real values before deployment.

NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://db-user:db-password@db-host:5432/togetherhere

# Frontend origin used by deployment routing (Vercel rewrite source origin)
ALLOWED_FRONTEND_ORIGIN=https://app.togetherhere.example

# Explicit CORS allowlist consumed by backend runtime
CORS_ALLOWED_ORIGINS=https://app.togetherhere.example

# Cookie domain settings for cross-subdomain cookie support
SESSION_COOKIE_DOMAIN=.togetherhere.example
CSRF_COOKIE_DOMAIN=.togetherhere.example
SESSION_COOKIE_NAME=__Secure-th_session
CSRF_COOKIE_NAME=__Secure-th_csrf
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_PATH=/
CSRF_COOKIE_PATH=/

# Authentication token secrets (set unique, high-entropy values)
AUTH_ACCESS_TOKEN_SECRET=replace-with-64+-char-random-secret
AUTH_REFRESH_TOKEN_SECRET=replace-with-64+-char-random-secret

# Logging
LOG_LEVEL=info

# Auth rate limiting / temporary lockout
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_BASE_BACKOFF_MS=1000
AUTH_RATE_LIMIT_MAX_BACKOFF_MS=60000
AUTH_RATE_LIMIT_LOCKOUT_THRESHOLD=10
AUTH_RATE_LIMIT_LOCKOUT_MS=900000
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
VERIFICATION_TOKEN_TTL_SECONDS=1800
AUTH_EXPOSE_TOKENS_IN_RESPONSE=false
APP_BASE_URL=https://app.togetherhere.example
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=TogetherHere <no-reply@togetherhere.example>
EMAIL_REPLY_TO_ADDRESS=support@togetherhere.example
RESEND_API_KEY=replace-with-resend-api-key
POSTMARK_SERVER_TOKEN=
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
