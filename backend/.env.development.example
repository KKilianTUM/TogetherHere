# TogetherHere backend development environment template
# Copy to .env.development and provide real secret values.

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/togetherhere

# Authentication secrets
AUTH_ACCESS_TOKEN_SECRET=replace-with-long-random-secret
AUTH_REFRESH_TOKEN_SECRET=replace-with-long-random-secret

# Cookies + frontend origin
COOKIE_DOMAIN=localhost
ALLOWED_FRONTEND_ORIGIN=http://localhost:5173

# Compatibility for current backend CORS config
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Auth rate limiting / temporary lockout
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_BASE_BACKOFF_MS=1000
AUTH_RATE_LIMIT_MAX_BACKOFF_MS=60000
AUTH_RATE_LIMIT_LOCKOUT_THRESHOLD=10
AUTH_RATE_LIMIT_LOCKOUT_MS=900000
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
