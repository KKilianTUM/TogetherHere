# TogetherHere backend production environment template
# Copy to .env.production and provide real secret values.

NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://db-user:db-password@db-host:5432/togetherhere

# Authentication secrets
AUTH_ACCESS_TOKEN_SECRET=replace-with-64+-char-random-secret
AUTH_REFRESH_TOKEN_SECRET=replace-with-64+-char-random-secret

# Cookies + frontend origin
COOKIE_DOMAIN=.togetherhere.example
ALLOWED_FRONTEND_ORIGIN=https://app.togetherhere.example

# Compatibility for current backend CORS config
CORS_ALLOWED_ORIGINS=https://app.togetherhere.example

# Logging
LOG_LEVEL=info
